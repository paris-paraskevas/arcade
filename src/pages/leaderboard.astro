---
import Base from '../layouts/Base.astro';
import { GAMES } from '../lib/games';
const playable = GAMES.filter((g) => g.status === 'playable');
---
<Base title="High scores — Arcade">
  <script is:inline src="/arcade-metrics.js"></script>
  <h2>HIGH SCORES</h2>
  <label class="pick">GAME
    <select id="game">
      {playable.map((g) => <option value={g.id}>{g.title}</option>)}
    </select>
  </label>

  <div class="board-wrap">
    <table id="board">
      <thead><tr><th>#</th><th>Player</th><th>Best</th><th>Plays</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>
  <p id="msg"></p>

  <style>
    .pick { display: inline-flex; align-items: center; gap: 10px; font-family: var(--pixel); font-size: 9px; color: var(--gold); margin: 18px 0; }
    select { font-family: var(--sans); font-size: 15px; padding: 9px 12px; border-radius: 8px; border: 2px solid var(--edge); background: var(--panel2); color: var(--ink); box-shadow: var(--sh); }
    .board-wrap { border: 3px solid var(--edge); border-radius: 12px; background: var(--panel); box-shadow: var(--sh-lg); overflow: hidden; max-width: 600px; }
    table { width: 100%; border-collapse: collapse; }
    th { font-family: var(--pixel); font-size: 8px; color: var(--cyan); text-align: left; padding: 13px 14px; border-bottom: 3px solid var(--edge); text-transform: uppercase; }
    td { padding: 11px 14px; border-bottom: 1px solid rgba(255,255,255,.06); font-size: 15px; color: var(--ink); }
    tbody tr:first-child td { color: var(--gold); font-weight: 700; }
    td:first-child, th:first-child { width: 46px; color: var(--muted); }
    #msg { color: var(--muted); font-size: 14px; margin-top: 14px; }
    @media (max-width: 560px) { th, td { padding: 9px 9px; font-size: 13px; } .pick { font-size: 8px; } }
  </style>

  <script>
    import { supabase } from '../lib/supabase';
    const BASE = 1000000000; // must match arcade-client.js encode base
    const sel = document.getElementById('game') as HTMLSelectElement;
    const tbody = document.querySelector('#board tbody') as HTMLElement;
    const msg = document.getElementById('msg') as HTMLElement;
    // Decode + format a stored "best" for display, per the game's metric.
    // Lower-is-better games store BASE - value, so we invert before formatting.
    function fmtBest(game: string, best: number): string {
      const m = ((window as any).ARCADE_METRICS || {})[game] || { dir: 'hi', unit: 'pts' };
      const v = m.dir === 'lo' ? BASE - best : best;
      if (m.unit === 'cs') {
        const s = v / 100;
        if (s < 60) return s.toFixed(2) + 's';
        return Math.floor(s / 60) + ':' + (s % 60).toFixed(2).padStart(5, '0');
      }
      if (m.unit === 'moves') return v.toLocaleString() + ' mv';
      return v.toLocaleString();
    }
    async function load() {
      const game = sel.value;
      tbody.innerHTML = '';
      msg.textContent = 'Loading…';
      const { data, error } = await supabase.from('leaderboard').select('username,best,plays').eq('game', game).order('best', { ascending: false }).limit(50);
      if (error) { msg.textContent = 'Error: ' + error.message; return; }
      if (!data || !data.length) { msg.textContent = 'No scores yet — be the first!'; return; }
      msg.textContent = '';
      data.forEach((r: any, i: number) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${i + 1}</td><td>${r.username ?? '—'}</td><td>${fmtBest(game, r.best)}</td><td>${r.plays}</td>`;
        tbody.appendChild(tr);
      });
    }
    sel.addEventListener('change', load);
    load();
  </script>
</Base>
