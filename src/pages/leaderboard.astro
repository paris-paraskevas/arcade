---
import Base from '../layouts/Base.astro';
import { GAMES } from '../lib/games';
const playable = GAMES.filter((g) => g.status === 'playable');
---
<Base title="Leaderboard — Arcade">
  <h2>Leaderboards</h2>
  <label class="pick">Game:
    <select id="game">
      {playable.map((g) => <option value={g.id}>{g.title}</option>)}
    </select>
  </label>

  <table id="board">
    <thead><tr><th>#</th><th>Player</th><th>Best</th><th>Plays</th></tr></thead>
    <tbody></tbody>
  </table>
  <p id="msg"></p>

  <style>
    .pick { display: inline-flex; align-items: center; gap: 8px; color: #9fb4d4; font-size: 14px; margin-bottom: 18px; }
    select { font: inherit; padding: 8px 12px; border-radius: 10px; border: 1px solid #2a3550; background: #10141f; color: #eaf2ff; }
    table { width: 100%; border-collapse: collapse; max-width: 560px; }
    th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #1d2536; }
    th { color: #6b7890; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
    td { color: #cdd6e4; }
    td:first-child, th:first-child { width: 40px; color: #6b7890; }
    #msg { color: #6b7890; font-size: 14px; margin-top: 14px; }
  </style>

  <script>
    import { supabase } from '../lib/supabase';
    const sel = document.getElementById('game') as HTMLSelectElement;
    const tbody = document.querySelector('#board tbody') as HTMLElement;
    const msg = document.getElementById('msg') as HTMLElement;

    async function load() {
      const game = sel.value;
      tbody.innerHTML = '';
      msg.textContent = 'Loading…';
      const { data, error } = await supabase
        .from('leaderboard')
        .select('username,best,plays')
        .eq('game', game)
        .order('best', { ascending: false })
        .limit(50);
      if (error) { msg.textContent = 'Error: ' + error.message; return; }
      if (!data || !data.length) { msg.textContent = 'No scores yet — be the first!'; return; }
      msg.textContent = '';
      data.forEach((r: any, i: number) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${i + 1}</td><td>${r.username ?? '—'}</td><td>${r.best}</td><td>${r.plays}</td>`;
        tbody.appendChild(tr);
      });
    }
    sel.addEventListener('change', load);
    load();
  </script>
</Base>
