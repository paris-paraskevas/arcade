---
import Base from '../layouts/Base.astro';
import { GAMES, ARCADE } from '../lib/games';
const tags = ['all', ...Array.from(new Set(GAMES.flatMap((g) => g.tags))).sort()];
const flat = (g: { gradient: string }) => (g.gradient.match(/#[0-9a-fA-F]{6}/) || ['#1e1940'])[0];
const bulbs = Array.from({ length: 16 });
---
<Base title="Arcade — 30 games">
  <section class="marquee">
    <div class="bulbs">{bulbs.map(() => <i></i>)}</div>
    <h1>ARCADE</h1>
    <p class="tag">{ARCADE.tagline}</p>
    <p class="coin">&#9656; INSERT COIN</p>
    <div class="bulbs">{bulbs.map(() => <i></i>)}</div>
  </section>

  <nav id="filters" aria-label="Filter games by tag">
    {tags.map((t) => <button class="chip" data-tag={t}>{t}</button>)}
  </nav>

  <div id="grid">
    {GAMES.map((g) => {
      const playable = g.status === 'playable' && g.path;
      const Tag = playable ? 'a' : 'div';
      return (
        <Tag class={`cab ${playable ? 'playable' : 'locked'}`} data-tags={g.tags.join(' ')} href={playable ? g.path : undefined}>
          <div class="screen" style={`background:${flat(g)}`}>
            <span class="emoji">{g.emoji}</span>
            {playable ? <span class="play">&#9654; PLAY</span> : <span class="soon">{g.status}</span>}
          </div>
          <div class="meta">
            <h3>{g.title}</h3>
            <p>{g.blurb}</p>
            <div class="tags">{g.tags.map((t) => <span class="t">{t}</span>)}</div>
          </div>
        </Tag>
      );
    })}
  </div>

  <style>
    /* Marquee — the lit top of an arcade cabinet */
    .marquee { position: relative; border: 3px solid var(--edge); border-radius: 14px; background: #120e24;
      box-shadow: var(--sh-lg); padding: 16px 16px 20px; text-align: center; overflow: hidden; margin-bottom: 30px; }
    .marquee::after { content: ""; position: absolute; inset: 0; pointer-events: none;
      background: repeating-linear-gradient(0deg, rgba(0,0,0,.2) 0 2px, transparent 2px 4px); opacity: .5; }
    .marquee h1 { font-family: var(--pixel); font-size: clamp(22px, 7vw, 44px); margin: 16px 0 0; color: var(--gold);
      letter-spacing: 2px; text-shadow: 3px 3px 0 var(--edge), 0 0 20px rgba(255,210,62,.45); }
    .marquee .tag { margin: 16px 0 0; color: var(--cyan); font-size: clamp(11px, 2.6vw, 14px); font-weight: 500; }
    .marquee .coin { font-family: var(--pixel); font-size: clamp(9px, 2.4vw, 12px); color: var(--hot);
      margin: 16px 0 0; animation: blink 1.1s steps(1) infinite; }
    @keyframes blink { 50% { opacity: .15; } }
    .bulbs { display: flex; justify-content: center; gap: clamp(8px, 3.4vw, 20px); }
    .bulbs i { width: 10px; height: 10px; border-radius: 50%; background: var(--gold);
      border: 2px solid var(--edge); box-shadow: 0 0 8px rgba(255,210,62,.7); }

    /* Filter chips — arcade buttons */
    #filters { display: flex; flex-wrap: wrap; justify-content: center; gap: 9px; margin: 0 0 28px; }
    .chip { font-family: var(--pixel); font-size: 9px; color: var(--ink); background: var(--panel2);
      border: 2px solid var(--edge); border-radius: 8px; padding: 9px 11px; cursor: pointer; box-shadow: var(--sh);
      transition: transform .08s, box-shadow .08s; }
    .chip:hover { transform: translate(-1px,-1px); box-shadow: var(--sh-lg); }
    .chip.active { background: var(--gold); color: var(--edge); transform: translate(2px,2px); box-shadow: 0 0 0 var(--edge); }

    /* Cartridge cards */
    #grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 210px), 1fr)); gap: 22px; }
    .cab { display: flex; flex-direction: column; text-decoration: none; color: inherit; background: var(--panel);
      border: 3px solid var(--edge); border-radius: 12px; box-shadow: var(--sh); overflow: hidden;
      transition: transform .1s, box-shadow .1s; }
    .cab.playable:hover { transform: translate(-3px,-3px); box-shadow: var(--sh-lg); }
    .cab.playable:active { transform: translate(2px,2px); box-shadow: 1px 1px 0 var(--edge); }
    .cab.locked { opacity: .5; }
    .screen { position: relative; aspect-ratio: 16 / 10; display: flex; align-items: center; justify-content: center;
      font-size: 62px; border-bottom: 3px solid var(--edge); text-shadow: 0 3px 0 rgba(0,0,0,.28); }
    .play { position: absolute; left: 10px; bottom: 10px; font-family: var(--pixel); font-size: 8px; color: var(--edge);
      background: var(--gold); border: 2px solid var(--edge); border-radius: 6px; padding: 5px 7px; }
    .soon { position: absolute; right: 10px; top: 10px; font-family: var(--pixel); font-size: 7px; color: var(--ink);
      background: rgba(0,0,0,.5); border: 2px solid var(--edge); border-radius: 6px; padding: 4px 6px; text-transform: uppercase; }
    .meta { padding: 13px 14px 15px; display: flex; flex-direction: column; gap: 8px; }
    .meta h3 { margin: 0; font-size: 18px; font-weight: 700; color: var(--ink); }
    .meta p { margin: 0; font-size: 13px; line-height: 1.45; color: var(--muted); flex: 1; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .t { font-family: var(--pixel); font-size: 7px; color: var(--muted); background: var(--panel2);
      border: 1px solid var(--edge); border-radius: 5px; padding: 4px 6px; text-transform: uppercase; }
  </style>

  <script>
    const chips = Array.from(document.querySelectorAll('#filters .chip'));
    const cards = Array.from(document.querySelectorAll('#grid .cab')) as HTMLElement[];
    let active = 'all';
    function apply() {
      cards.forEach((c) => {
        const t = (c.getAttribute('data-tags') || '').split(' ');
        c.style.display = active === 'all' || t.includes(active) ? '' : 'none';
      });
      chips.forEach((ch) => ch.classList.toggle('active', ch.getAttribute('data-tag') === active));
    }
    chips.forEach((ch) => ch.addEventListener('click', () => { active = ch.getAttribute('data-tag') || 'all'; apply(); }));
    apply();
  </script>
</Base>
