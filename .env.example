# Hosted Supabase — these are PUBLIC, client-safe values (the anon key is meant
# to ship to the browser; Row-Level Security protects the data).
# Get the anon key with:
#   supabase projects api-keys --project-ref drkqjfcejhffwpbptzmv
PUBLIC_SUPABASE_URL="https://drkqjfcejhffwpbptzmv.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="eyJ...your-anon-key..."

